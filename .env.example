# PocketBase admin credentials (set on first run)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme123

# Fetcher service account (must match a user created in PocketBase)
PB_SERVICE_EMAIL=fetcher@local.internal
PB_SERVICE_PASSWORD=changeme456

# Internal URL used by Docker services to talk to PocketBase
POCKETBASE_URL=http://pocketbase:8090

# Public URL used by the browser (leave as-is for local dev)
PUBLIC_POCKETBASE_URL=http://localhost:8090
